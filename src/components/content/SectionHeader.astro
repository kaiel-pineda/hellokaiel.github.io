---
type Props = {
	count?: number;
	pluralLabel?: string;
	singularLabel?: string;
	title: string;
};

const { count, pluralLabel, singularLabel, title } = Astro.props;
const hasCount = typeof count === "number";
const resolvedPluralLabel = pluralLabel ?? (singularLabel ? `${singularLabel}s` : undefined);
---

<header class="section-header">
	<div class="section-heading-stack">
		<h1 class="section-title">{title}</h1>
		<div class="section-meta-row">
			{
				hasCount && singularLabel && resolvedPluralLabel ? (
					<span class="section-count">
						{count}
						{count === 1 ? singularLabel : resolvedPluralLabel}
					</span>
				) : (
					<span />
				)
			}
		</div>
	</div>
</header>
