---
type TaxonomySummary = {
	count: number;
	label: string;
	value: string;
};

type Props = {
	emptyDescription: string;
	emptyTitle: string;
	getHref: (value: string) => string;
	items: TaxonomySummary[];
};

const { emptyDescription, emptyTitle, getHref, items } = Astro.props;
---

{
	items.length > 0 ? (
		<div class="directory-entry-list">
			{items.map((item) => (
				<div class="directory-entry">
					<div>
						<a class="directory-entry-link" href={getHref(item.value)}>
							{item.label}
						</a>
					</div>
					<div>
						<span class="link-meta-sm">
							{item.count}
							{item.count === 1 ? " entry" : " entries"}
						</span>
					</div>
				</div>
			))}
		</div>
	) : (
		<div class="directory-empty-state">
			<span class="directory-empty-title">{emptyTitle}</span>
			<span class="directory-empty-description">{emptyDescription}</span>
		</div>
	)
}
