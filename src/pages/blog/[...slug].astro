---
import { getCollection, render, type CollectionEntry } from "astro:content";
import type { BottomNavigationContext } from "../../components/masters/site-navigation/bottom-navigation";
import SiteAuthorCard from "../../components/microformats/SiteAuthorCard.astro";
import EntryTaxonomy from "../../components/taxonomy/EntryTaxonomy.astro";
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import SiteFooter from "../../components/masters/SiteFooter.astro";
import EntryAppreciationSection from "../../components/content/EntryAppreciationSection.astro";
import RelatedEntries from "../../partials/RelatedEntries.astro";
import { getEntryReadingTime } from "../../utils/reading-time";

type Props = CollectionEntry<"blog">;

export async function getStaticPaths() {
	const entries = await getCollection("blog");
	return entries.map((entry: Props) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

const entry = Astro.props;
const { Content } = await render(entry);
const readingTime = await getEntryReadingTime(entry);
const bottomNavigationContext: BottomNavigationContext = {
	eyebrow: "Blog",
	primary: entry.data.title,
};
---

<DefaultLayout
	title={entry.data.title}
	bottomNavigationContext={bottomNavigationContext}
	seo={{
		description: entry.data.description ?? entry.data.subheading ?? "Article from the blog of Karl Pineda.",
		keywords: [...entry.data.categories, ...entry.data.tags],
		publishedTime: entry.data.date,
		section: "Blog",
		type: "article",
	}}
>
	<div class="entry-shell">
		<article class="entry-frame h-entry">
			<header class="entry-header">
				<div class="mx-auto max-w-screen-md px-6">
					<div class="entry-header-stack">
						<SiteAuthorCard />
						{entry.data.description && <p class="sr-only p-summary">{entry.data.description}</p>}
						<time class="entry-date-label dt-published" datetime={new Date(entry.data.date).toISOString()}>
							{
								new Date(entry.data.date).toLocaleDateString("en-us", {
									year: "numeric",
									month: "short",
									day: "numeric",
								})
							}
						</time>

						<h1 class="entry-title p-name">
							{entry.data.title}
						</h1>

						<EntryTaxonomy categories={entry.data.categories} tags={entry.data.tags} size="base" />

						{
							readingTime && (
								<div class="max-w-fit bg-dynamic-neutral-200 p-3">
									<div class="flex items-center gap-x-3">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" class="fill-dynamic-neutral-700">
											<path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
											<path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8 a7 7 0 0 1 14 0z" />
										</svg>
										<span class="text-sm font-medium capitalize text-dynamic-neutral-700">{readingTime.label}</span>
									</div>
								</div>
							)
						}
					</div>
				</div>
			</header>

			<main>
				<div class="entry-body e-content">
					<Content />
				</div>
			</main>

			<EntryAppreciationSection entryKey={`blog:${entry.id}`} kind="kudos" />
		</article>
	</div>

	<RelatedEntries currentEntry={entry} />

	<SiteFooter class="border-dynamic-neutral-300 bg-dynamic-neutral-100 text-dynamic-neutral-600" />
</DefaultLayout>
