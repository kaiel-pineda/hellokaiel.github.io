---
import { type CollectionEntry } from "astro:content";
import SectionHeader from "../../components/content/SectionHeader.astro";
import PageScaffold from "../../components/layout/PageScaffold.astro";
import EntryTaxonomy from "../../components/taxonomy/EntryTaxonomy.astro";
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import SiteFooter from "../../components/masters/SiteFooter.astro";
import { groupEntriesByYear } from "../../utils/group-entries";
import { getOptionalCollection } from "../../utils/content";

type Props = CollectionEntry<"research">;
const entries: Props[] = await getOptionalCollection("research", "./src/content/research");

const entriesByYear = groupEntriesByYear(entries);
---

<DefaultLayout title="Research" showBottomNavigation={false} seo={{ description: "Research, studies, and technical observations by Karl Pineda." }}>
	<PageScaffold mainClass="h-feed">
		<SectionHeader count={entries.length} singularLabel="study" pluralLabel="studies" title="Research" />
		{
			entriesByYear.length > 0 ? (
				<section>
					<div class="collection-groups">
						{entriesByYear.map(([year, entriesFromYear]) => (
							<div class="collection-group-alt border-b border-dynamic-neutral-300 last:border-b-0">
								<div>
									<span class="font-sans text-base font-medium leading-normal text-dynamic-neutral-700">{year}</span>
								</div>

								<div class="collection-entry-list">
									{entriesFromYear.map((entry) => (
										<div class="border-t border-dynamic-neutral-300 pt-4">
											<article class="grid grid-cols-[1fr_2fr_1fr] items-center gap-x-3 h-entry">
												<time class="dt-published font-sans text-sm font-medium leading-normal text-dynamic-neutral-700" datetime={new Date(entry.data.date).toISOString()}>
													{new Date(entry.data.date).toLocaleDateString("en-us", {
														year: "numeric",
														month: "short",
														day: "numeric",
													})}
												</time>

												<div>
													<a class="link-title link-focus p-name u-url" href={`/research/${entry.id}/`}>
														{entry.data.title}
													</a>
												</div>
												{entry.data.description && <p class="sr-only p-summary">{entry.data.description}</p>}

												<EntryTaxonomy categories={entry.data.categories} tags={entry.data.tags} />
											</article>
										</div>
									))}
								</div>
							</div>
						))}
					</div>
				</section>
			) : (
				<section>
					<div class="inline-flex flex-col gap-y-4">
						<span class="font-display text-base font-semibold leading-normal text-dynamic-neutral-950">Empty Research Collection</span>
						<span class="font-sans text-base font-normal leading-normal text-dynamic-neutral-700">There are currently no studies available.</span>
					</div>
				</section>
			)
		}
	</PageScaffold>

	<SiteFooter />
</DefaultLayout>
