---
import SectionHeader from "../../components/content/SectionHeader.astro";
import PageScaffold from "../../components/layout/PageScaffold.astro";
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import SiteFooter from "../../components/masters/SiteFooter.astro";
import TaxonomyEntryGroups from "../../components/taxonomy/TaxonomyEntryGroups.astro";
import { buildCategoryIndex, getCategoryBySlug } from "../../utils/categories";
import { getAllContentEntries } from "../../utils/content-entries";

const { category: categorySlug } = Astro.params;

const allEntries = await getAllContentEntries();
const currentCategory = getCategoryBySlug(allEntries, categorySlug ?? "");

if (!currentCategory) {
	throw new Error(`Unknown category: ${categorySlug}`);
}

export async function getStaticPaths() {
	return buildCategoryIndex(await getAllContentEntries()).map((category) => ({
		params: { category: category.slug },
	}));
}
---

<DefaultLayout title={currentCategory.label} seo={{ description: `Entries filed under ${currentCategory.label}.` }}>
	<PageScaffold>
		<SectionHeader count={currentCategory.count} singularLabel="entry" pluralLabel="entries" title={currentCategory.label} />
		<section>
			<TaxonomyEntryGroups entries={currentCategory.entries} />
		</section>
	</PageScaffold>

	<SiteFooter />
</DefaultLayout>
