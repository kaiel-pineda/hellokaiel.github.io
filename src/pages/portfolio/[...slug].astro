---
import { getCollection, render, type CollectionEntry } from "astro:content";
import type { BottomNavigationContext } from "../../components/masters/site-navigation/bottom-navigation";
import SiteAuthorCard from "../../components/microformats/SiteAuthorCard.astro";
import EntryTaxonomy from "../../components/taxonomy/EntryTaxonomy.astro";
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import SiteFooter from "../../components/masters/SiteFooter.astro";
import ThemeScope from "../../components/theming/ThemeScope.astro";

type Props = CollectionEntry<"portfolio">;

export async function getStaticPaths() {
	const entries = await getCollection("portfolio");
	return entries.map((entry: Props) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

const entry = Astro.props;
const { Content } = await render(entry);
const bottomNavigationContext: BottomNavigationContext = {
	eyebrow: "Portfolio",
	primary: entry.data.title,
};
---

<DefaultLayout
	title={entry.data.title}
	bottomNavigationContext={bottomNavigationContext}
	seo={{
		description: entry.data.description,
		keywords: [...entry.data.categories, ...entry.data.tags],
		publishedTime: entry.data.date,
		section: "Portfolio",
		type: "article",
	}}
>
	<article class="h-entry">
		<div class="my-24">
			<header class="mb-6">
				<div class="mx-auto max-w-7xl">
					<div class="grid grid-cols-1 gap-6 lg:grid-cols-[auto_auto]">
						<div class="row-span-1">
							<div class="mx-auto max-w-screen-md px-6">
								<div class="flex flex-col gap-y-3">
									<SiteAuthorCard />
									<time class="dt-published font-sans text-base font-medium leading-normal text-dynamic-neutral-700" datetime={new Date(entry.data.date).toISOString()}>
										{
											new Date(entry.data.date).toLocaleDateString("en-us", {
												year: "numeric",
												month: "short",
												day: "numeric",
											})
										}
									</time>

									<h1 class="entry-title p-name">
										{entry.data.title}
									</h1>

									<EntryTaxonomy categories={entry.data.categories} tags={entry.data.tags} size="base" />
								</div>
							</div>
						</div>

						<div class="row-start-2">
							<div class="mx-auto max-w-screen-md px-6">
								<div class="p-summary prose-xl prose-neutral font-sans text-dynamic-neutral-900">
									{entry.data.description}
								</div>
							</div>
						</div>

						<div class="row-start-3 lg:row-start-2">
							<div class="mx-auto max-w-screen-md px-6">
								{
									entry.data.metadata &&
										Object.entries(entry.data.metadata).map(([key, value]) => (
											<div class="border-x border-t border-dynamic-neutral-300 p-3 last-of-type:border-b">
												<div class="flex items-center gap-x-3">
													<span class="text-sm font-semibold capitalize leading-normal text-dynamic-neutral-950">{key}</span>
													<span class="text-base leading-normal text-dynamic-neutral-700">{value}</span>
												</div>
											</div>
										))
								}
							</div>
						</div>
					</div>
				</div>
			</header>
		</div>

		<ThemeScope theme="black">
			<section data-navigation-theme="black" class="e-content flex-1 bg-dynamic-neutral-0 py-24">
				<Content />
			</section>
			<SiteFooter class="border-dynamic-neutral-300 bg-dynamic-neutral-0 text-dynamic-neutral-600" />
		</ThemeScope>
	</article>
</DefaultLayout>
